  "about": {
    "pageTitle": "About Us",
    "metaDesc": "Learn more about PetZone's mission — a platform connecting homeless animals with loving homes through a network of volunteers",
    "hero": {
      "badge": "Our Mission",
      "title": "Every Animal Deserves a Home",
      "subtitle": "PetZone is a platform that connects homeless animals with people ready to give them a home. We believe that together we can make the world a better place — one animal at a time."
    },
    "mission": {
      "title": "Why We Exist",
      "card1": {
        "title": "The Problem",
        "desc": "Every year thousands of animals end up on the streets or in shelters. They need more than just a roof — they need love and a permanent family."
      },
      "card2": {
        "title": "Our Solution",
        "desc": "We built a convenient tool that helps volunteers represent their animals and find them true owners."
      },
      "card3": {
        "title": "The Result",
        "desc": "A transparent system where anyone can browse animals, contact a volunteer, and learn the adoption or care conditions."
      }
    },
    "values": {
      "title": "Our Values",
      "v1": {
        "title": "Transparency",
        "desc": "All information about animals and volunteers is open. No hidden conditions."
      },
      "v2": {
        "title": "Care",
        "desc": "Every decision is made with the wellbeing of animals and convenience of volunteers in mind."
      },
      "v3": {
        "title": "Community",
        "desc": "We build a network of caring people who together make a difference."
      },
      "v4": {
        "title": "Accessibility",
        "desc": "The platform is completely free for volunteers and people looking for a pet."
      }
    },
    "team": {
      "title": "Who's Behind This",
      "desc": "PetZone is a pet project created out of love for animals and a desire to use technology for a good cause. The project is actively developing and open to collaboration.",
      "founder": "Founder & Developer"
    },
    "cta": {
      "title": "Join the Community",
