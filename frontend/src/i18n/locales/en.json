  "faq": {
    "pageTitle": "Frequently Asked Questions",
    "metaDesc": "Answers to common questions about PetZone — adopting animals, registering as a volunteer, and how the platform works",
    "badge": "FAQ",
    "subtitle": "Find answers to the most common questions about the platform",
    "category": {
      "all": "All",
      "general": "General",
      "adoption": "Adoption",
      "volunteers": "For Volunteers",
      "technical": "Technical"
    },
    "ctaTitle": "Didn't find your answer?",
    "ctaSubtitle": "Browse animals or become a volunteer — together we help more",
    "q1": {
      "q": "What is PetZone?",
      "a": "PetZone is a free platform that connects volunteers who rescue animals with people ready to give them a home. We are not a shelter — we are the link between animals and their future owners."
    },
    "q2": {
      "q": "Do I need an account to browse animals?",
      "a": "No. You can browse animal profiles and volunteer profiles without registering. Registration is only required for volunteers to post their animals."
    },
    "q3": {
      "q": "How do I adopt an animal?",
      "a": "Find an animal you like and visit the responsible volunteer's profile. Their contact details are listed there — write to them directly to arrange a meeting and discuss the adoption terms."
    },
    "q4": {
      "q": "Is there a fee to adopt?",
      "a": "The PetZone platform is free. Adoption conditions (vaccination, neutering, deposit) are set by the volunteer individually for each animal."
    },
    "q5": {
      "q": "How do I know if an animal is healthy?",
      "a": "Each animal's page shows vaccination and neutering status. For more health details, contact the volunteer directly."
    },
    "q6": {
      "q": "How do I become a volunteer on PetZone?",
      "a": "Click 'Become a Volunteer', fill in the application form, and submit it. An administrator will review your application, and if approved — you will get access to the volunteer dashboard."
    },
    "q7": {
      "q": "What can I do in the volunteer dashboard?",
      "a": "Add and edit animal profiles, upload photos, set contact details and payment info for donations, and publish news and announcements."
    },
    "q8": {
      "q": "How many animals can I list?",
      "a": "There is no limit. You can add as many animals as you care for."
    },
    "q9": {
      "q": "What languages does the platform support?",
      "a": "The platform supports 5 languages: Ukrainian, English, Polish, German, and French. You can change the language in the top right corner."
    },
    "q10": {
      "q": "Does the site work on mobile?",
      "a": "Yes, PetZone is fully responsive and works on mobile devices and tablets."
    }
  },
