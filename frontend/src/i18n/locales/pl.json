  "faq": {
    "pageTitle": "Najczęściej zadawane pytania",
    "metaDesc": "Odpowiedzi na najczęstsze pytania dotyczące PetZone — adopcja zwierząt, rejestracja wolontariuszy i działanie platformy",
    "badge": "FAQ",
    "subtitle": "Znajdź odpowiedzi na najczęstsze pytania dotyczące platformy",
    "category": {
      "all": "Wszystkie",
      "general": "Ogólne",
      "adoption": "Adopcja",
      "volunteers": "Dla wolontariuszy",
      "technical": "Techniczne"
    },
    "ctaTitle": "Nie znalazłeś odpowiedzi?",
    "ctaSubtitle": "Przeglądaj zwierzęta lub zostań wolontariuszem — razem pomagamy więcej",
    "q1": {
      "q": "Czym jest PetZone?",
      "a": "PetZone to bezpłatna platforma łącząca wolontariuszy ratujących zwierzęta z osobami gotowymi dać im dom. Nie jesteśmy schroniskiem — jesteśmy łącznikiem między zwierzętami a przyszłymi właścicielami."
    },
    "q2": {
      "q": "Czy potrzebuję konta, by przeglądać zwierzęta?",
      "a": "Nie. Profile zwierząt i wolontariuszy można przeglądać bez rejestracji. Rejestracja jest wymagana tylko dla wolontariuszy, aby publikować swoich podopiecznych."
    },
    "q3": {
      "q": "Jak adoptować zwierzę?",
      "a": "Znajdź zwierzę, które ci się spodoba, i odwiedź profil odpowiedzialnego wolontariusza. Znajdziesz tam jego dane kontaktowe — napisz bezpośrednio i ustal warunki przekazania."
    },
    "q4": {
      "q": "Czy adopcja jest płatna?",
      "a": "Platforma PetZone jest bezpłatna. Warunki adopcji (szczepienia, sterylizacja, kaucja) ustala wolontariusz indywidualnie dla każdego zwierzęcia."
    },
    "q5": {
      "q": "Jak sprawdzić, czy zwierzę jest zdrowe?",
      "a": "Na stronie każdego zwierzęcia pokazany jest status szczepień i kastracji. Po więcej szczegółów skontaktuj się bezpośrednio z wolontariuszem."
    },
    "q6": {
      "q": "Jak zostać wolontariuszem na PetZone?",
      "a": "Kliknij 'Zostań wolontariuszem', wypełnij formularz zgłoszeniowy i wyślij. Administrator rozpatrzy wniosek, a po zatwierdzeniu — otrzymasz dostęp do panelu wolontariusza."
    },
    "q7": {
      "q": "Co mogę robić w panelu wolontariusza?",
      "a": "Dodawać i edytować profile zwierząt, przesyłać zdjęcia, podawać dane kontaktowe i dane do wpłat, publikować aktualności i ogłoszenia."
    },
    "q8": {
      "q": "Ile zwierząt mogę dodać?",
      "a": "Bez ograniczeń. Możesz dodać tyle zwierząt, ile masz pod opieką."
