  "faq": {
    "pageTitle": "Häufig gestellte Fragen",
    "metaDesc": "Antworten auf häufige Fragen zu PetZone — Tieradoption, Freiwilligenregistrierung und Funktionsweise der Plattform",
    "badge": "FAQ",
    "subtitle": "Finden Sie Antworten auf die häufigsten Fragen zur Plattform",
    "category": {
      "all": "Alle",
      "general": "Allgemein",
      "adoption": "Adoption",
      "volunteers": "Für Freiwillige",
      "technical": "Technisch"
    },
    "ctaTitle": "Keine Antwort gefunden?",
    "ctaSubtitle": "Stöbern Sie in Tieren oder werden Sie Freiwilliger — gemeinsam helfen wir mehr",
    "q1": {
      "q": "Was ist PetZone?",
      "a": "PetZone ist eine kostenlose Plattform, die Freiwillige, die Tiere retten, mit Menschen verbindet, die ihnen ein Zuhause geben möchten. Wir sind kein Tierheim — wir sind das Bindeglied zwischen Tieren und ihren zukünftigen Besitzern."
    },
    "q2": {
      "q": "Benötige ich ein Konto, um Tiere zu durchsuchen?",
      "a": "Nein. Tierprofile und Freiwilligenprofile können ohne Registrierung durchsucht werden. Eine Registrierung ist nur für Freiwillige erforderlich, um ihre Tiere zu veröffentlichen."
    },
    "q3": {
      "q": "Wie adoptiere ich ein Tier?",
      "a": "Finden Sie ein Tier, das Ihnen gefällt, und besuchen Sie das Profil des zuständigen Freiwilligen. Dort finden Sie seine Kontaktdaten — schreiben Sie direkt und vereinbaren Sie ein Treffen."
    },
    "q4": {
      "q": "Kostet die Adoption etwas?",
      "a": "Die PetZone-Plattform ist kostenlos. Adoptionsbedingungen (Impfung, Kastration, Kaution) werden vom Freiwilligen individuell für jedes Tier festgelegt."
    },
    "q5": {
      "q": "Wie weiß ich, ob das Tier gesund ist?",
      "a": "Auf jeder Tierseite werden Impf- und Kastrationsstatus angezeigt. Für weitere Gesundheitsdetails wenden Sie sich direkt an den Freiwilligen."
    },
    "q6": {
      "q": "Wie werde ich Freiwilliger bei PetZone?",
      "a": "Klicken Sie auf 'Freiwilliger werden', füllen Sie das Antragsformular aus und senden Sie es ab. Ein Administrator prüft Ihren Antrag und bei Genehmigung erhalten Sie Zugang zum Freiwilligen-Dashboard."
    },
    "q7": {
      "q": "Was kann ich im Freiwilligen-Dashboard tun?",
      "a": "Tierprofile hinzufügen und bearbeiten, Fotos hochladen, Kontaktdaten und Zahlungsinformationen hinterlegen sowie Neuigkeiten und Ankündigungen veröffentlichen."
    },
    "q8": {
      "q": "Wie viele Tiere kann ich einstellen?",
      "a": "Es gibt keine Begrenzung. Sie können so viele Tiere hinzufügen, wie Sie betreuen."
    },
    "q9": {
      "q": "Welche Sprachen werden unterstützt?",
      "a": "Die Plattform unterstützt 5 Sprachen: Ukrainisch, Englisch, Polnisch, Deutsch und Französisch. Die Sprache kann oben rechts geändert werden."
    },
    "q10": {
      "q": "Funktioniert die Website auf Mobilgeräten?",
      "a": "Ja, PetZone ist vollständig responsiv und funktioniert auf Mobilgeräten und Tablets."
    }
  },
