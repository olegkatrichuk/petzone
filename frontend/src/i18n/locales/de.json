  "about": {
    "pageTitle": "Über uns",
    "metaDesc": "Erfahren Sie mehr über die Mission von PetZone — eine Plattform, die obdachlose Tiere mit liebevollen Zuhausen durch ein Netzwerk von Freiwilligen verbindet",
    "hero": {
      "badge": "Unsere Mission",
      "title": "Jedes Tier verdient ein Zuhause",
      "subtitle": "PetZone ist eine Plattform, die obdachlose Tiere mit Menschen verbindet, die bereit sind, ihnen ein Zuhause zu geben. Wir glauben, dass wir gemeinsam die Welt verbessern können — ein Tier nach dem anderen."
    },
    "mission": {
      "title": "Warum wir existieren",
      "card1": {
        "title": "Das Problem",
        "desc": "Jedes Jahr landen Tausende von Tieren auf der Straße oder in Tierheimen. Sie brauchen nicht nur ein Dach — sie brauchen Liebe und eine dauerhafte Familie."
      },
      "card2": {
        "title": "Unsere Lösung",
        "desc": "Wir haben ein praktisches Tool entwickelt, das Freiwilligen hilft, ihre Schützlinge vorzustellen und echte Besitzer zu finden."
      },
      "card3": {
        "title": "Das Ergebnis",
        "desc": "Ein transparentes System, in dem jeder Tiere durchsuchen, Freiwillige kontaktieren und Adoptionsbedingungen erfahren kann."
      }
    },
    "values": {
      "title": "Unsere Werte",
      "v1": {
        "title": "Transparenz",
        "desc": "Alle Informationen über Tiere und Freiwillige sind offen. Keine versteckten Bedingungen."
      },
      "v2": {
        "title": "Fürsorge",
        "desc": "Jede Entscheidung wird mit Blick auf das Wohlbefinden der Tiere und die Bequemlichkeit der Freiwilligen getroffen."
      },
      "v3": {
        "title": "Gemeinschaft",
        "desc": "Wir bauen ein Netzwerk fürsorglicher Menschen auf, die gemeinsam einen Unterschied machen."
      },
      "v4": {
        "title": "Zugänglichkeit",
        "desc": "Die Plattform ist für Freiwillige und Tiersucher völlig kostenlos."
      }
    },
    "team": {
      "title": "Wer dahintersteckt",
      "desc": "PetZone ist ein Herzensprojekt, das aus Liebe zu Tieren und dem Wunsch entstanden ist, Technologie für einen guten Zweck einzusetzen. Das Projekt entwickelt sich aktiv weiter und ist offen für Zusammenarbeit.",
      "founder": "Gründer & Entwickler"
    },
